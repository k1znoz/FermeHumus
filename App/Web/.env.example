# Obtenu sur sanity.io/manage
VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=production

# Token Sanity avec permission "Editor" (sanity.io/manage → API → Tokens)
SANITY_API_WRITE_TOKEN=votre-token-ici

# Mot de passe espace équipe (admin stock) — ne jamais committer la valeur réelle
ADMIN_PASSWORD=changez-moi
